FOCUS_AGENT_GEMINI_KEY=your_api_key_here

# Optional extra Gemini keys. CLUTCH rotates/fails over across them on rate
# limits or an invalid key, so one bad key never takes Gemini down.
# FOCUS_AGENT_GEMINI_KEY_2=
# FOCUS_AGENT_GEMINI_KEY_3=
# FOCUS_AGENT_GEMINI_KEY_4=

# Optional model overrides (defaults shown). Free-tier Flash models only.
# FOCUS_AGENT_TTS_MODEL=gemini-2.5-flash-preview-tts
# FOCUS_AGENT_EMBED_MODEL=gemini-embedding-001

# Email delivery for proactive alerts (Resend). Without it, sends are simulated.
RESEND_API_KEY=your_resend_api_key_here

# Server-side proactive alerts (Cloud Scheduler -> Cloud Run -> Firestore).
# Set these on the deployed Cloud Run service, not for local dev:
#   FIRESTORE_PROJECT_ID = your GCP project id (where Firestore is enabled)
#   CRON_SECRET          = shared secret the Cloud Scheduler job sends as a Bearer token
# FIRESTORE_PROJECT_ID=
# CRON_SECRET=

# Optional testing fallback. Gemini remains primary; this is used only when
# Gemini is unavailable, quota-limited, or times out.
NVIDIA_API_KEY=your_nvidia_api_key_here
FOCUS_AGENT_FALLBACK_PROVIDER=NVIDIA
FOCUS_AGENT_FALLBACK_BASE_URL=https://integrate.api.nvidia.com/v1
FOCUS_AGENT_FALLBACK_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
